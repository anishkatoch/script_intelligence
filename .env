OPENAI_API_KEY=key

# Redis — job queue broker and result backend
REDIS_URL=redis://localhost:6379/0

# Celery — how many analyses run in parallel
CELERY_MAX_WORKERS=4
CELERY_TASK_TIMEOUT=600

# Rate limiting — per user session
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=3600

# LLM retry settings
LLM_MAX_RETRIES=3
LLM_RETRY_MIN_WAIT=2
LLM_RETRY_MAX_WAIT=30

# ChromaDB — where persistent job data is stored
CHROMA_BASE_DIR=./chroma_db
